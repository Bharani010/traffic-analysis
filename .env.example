# ==============================================================================
# Application
# ==============================================================================
APP_NAME=traffic-analysis-platform
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ==============================================================================
# Backend — FastAPI
# ==============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================================================
# Database — PostgreSQL
# ==============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=traffic_analysis
POSTGRES_USER=traffic_user
POSTGRES_PASSWORD=traffic_password_change_me
DATABASE_URL=postgresql+asyncpg://traffic_user:traffic_password_change_me@postgres:5432/traffic_analysis

# ==============================================================================
# Redis
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==============================================================================
# Frontend
# ==============================================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ==============================================================================
# PySpark
# ==============================================================================
SPARK_MASTER=local[*]
SPARK_APP_NAME=traffic-analysis-spark

# ==============================================================================
# Monitoring
# ==============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
